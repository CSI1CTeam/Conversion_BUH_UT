|//ДопУсловие
|УПОРЯДОЧИТЬ ПО
|	Дата";
			   
Запрос.УстановитьПараметр("парСчет19",	ПланыСчетов.Хозрасчетный.НДСпоПриобретеннымЦенностям);
Запрос.УстановитьПараметр("Счет6802",	ПланыСчетов.Хозрасчетный.НДС);
Запрос.УстановитьПараметр("Счет6832",	ПланыСчетов.Хозрасчетный.НДСНалоговогоАгента);
Запрос.УстановитьПараметр("парСписокСчетов", Новый Массив);
Запрос.УстановитьПараметр("парНачалоПериода", Новый Граница(НачалоДня(ДатаНачала), ВидГраницы.Включая));
Запрос.УстановитьПараметр("парКонецПериода", Новый Граница(КонецДня(ДатаОкончания), ВидГраницы.Включая));
Запрос.УстановитьПараметр("Организация", Параметры.Организация);

Если ЗначениеЗаполнено(Параметры.ДопУсловие) Тогда
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "//ДопУсловие", Параметры.ДопУсловие); 
КонецЕсли;

ВыборкаДанных = Запрос.Выполнить().Выгрузить();

Для Каждого СтрокаПроводки из ВыборкаДанных Цикл
	//СтрокаПроводки.ДокументБУ = СтрЗаменить(СтрокаПроводки.ДокументБУ, "Реализация (акт, накладная)", "Реализация товаров и услуг");
	СтрокаПроводки.ДокументБУ = СтрЗаменить(СтрокаПроводки.ДокументБУ, "Реализация (акт, накладная, УПД)", "Реализация товаров и услуг");
	//СтрокаПроводки.ДокументБУ = СтрЗаменить(СтрокаПроводки.ДокументБУ, "Поступление (акт, накладная)", "Поступление товаров и услуг");
	СтрокаПроводки.ДокументБУ = СтрЗаменить(СтрокаПроводки.ДокументБУ, "Поступление (акт, накладная, УПД)", "Поступление товаров и услуг");
	СтрокаПроводки.ДокументБУ = СтрЗаменить(СтрокаПроводки.ДокументБУ, "Расход материалов", "Требование-накладная");
	СтрокаПроводки.Содержание = "СчетДт: " + СтрокаПроводки.СчетДт + " " + СтрокаПроводки.СубконтоДт1 + "/" + СтрокаПроводки.СубконтоДт2 + "/" + СтрокаПроводки.СубконтоДт3 + " СчетКт: " + СтрокаПроводки.СчетКт + " " + СтрокаПроводки.СубконтоКт1 + "/" + СтрокаПроводки.СубконтоКт2 + "/" + СтрокаПроводки.СубконтоКт3 + " СУММА " + СтрокаПроводки.Сумма;
КонецЦикла;</ПередОбработкойПравила>
		</Правило>
	</ПравилаВыгрузкиДанных>
	<ПравилаОчисткиДанных/>
	<Алгоритмы>
		<Алгоритм Имя="НайтиДокументАналогВУТ" ИспользуетсяПриЗагрузке="true">
			<Текст>	Если СсылкаНаОбъект.ТипОбъекта = "Поступление из переработки" Тогда
		Запрос = Новый Запрос("ВЫБРАТЬ
		                      |	ПоступлениеТоваровУслуг.Ссылка
		                      |ИЗ
		                      |	Документ.ПоступлениеТоваровУслуг КАК ПоступлениеТоваровУслуг
		                      |ГДЕ
		                      |	НАЧАЛОПЕРИОДА(ПоступлениеТоваровУслуг.Дата, ГОД) = &amp;Дата
		                      |	И ПоступлениеТоваровУслуг.ВидОперации = &amp;ВидОперации
		                      |	И ПоступлениеТоваровУслуг.СуммаДокумента = &amp;СуммаДокумента
		                      |	И ПоступлениеТоваровУслуг.ДоговорКонтрагента = &amp;ДоговорКонтрагента");
		Запрос.УстановитьПараметр("ВидОперации", Перечисления.ВидыОперацийПоступлениеТоваровУслуг.ПоступлениеИзПереработки);
		Запрос.УстановитьПараметр("СуммаДокумента", СвойстваПоиска["СуммаДокумента"]);
		Запрос.УстановитьПараметр("ДоговорКонтрагента", СвойстваПоиска["ДоговорКонтрагента"]);
	Иначе	
		лТипДокумента = СтрЗаменить(СсылкаНаОбъект.ТипОбъекта, " ", "");
		Запрос = Новый Запрос("ВЫБРАТЬ
		                      |	ДокументыПоиска.Ссылка
		                      |ИЗ
		                      |	Документ."+лТипДокумента+" КАК ДокументыПоиска
		                      |ГДЕ
		                      |	ДокументыПоиска.Номер = &amp;Номер
		                      |	И НАЧАЛОПЕРИОДА(ДокументыПоиска.Дата, ГОД) = &amp;Дата");
		Запрос.УстановитьПараметр("Номер", СсылкаНаОбъект.Номер);
	КонецЕсли;	
	Запрос.УстановитьПараметр("Дата", НачалоГода(СсылкаНаОбъект.Дата));
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ТекОбъект = СсылкаНаОбъект.ПолучитьОбъект();
		ТекОбъект.ДокументАналогВУТ = Выборка.Ссылка;
		ТекОбъект.Записать();
	КонецЕсли;</Текст>
		</Алгоритм>
		<Алгоритм Имя="ПоискВ_УБИ_ПотерянныеДокументыИзБУ" ИспользуетсяПриЗагрузке="true">
			<Текст>
лДокументБУ = ?(ТипОбъекта = Тип("СправочникСсылка.УБИ_ПотерянныеДокументыИзБУ"), СвойстваПоиска["Наименование"], лДокументБУ);			  
СсылкаНаОбъект = Справочники.УБИ_ПотерянныеДокументыИзБУ.НайтиПоРеквизиту("УникальныйИдентификатор", СвойствоУникальныйИдентификатор);
Если ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
	Если СсылкаНаОбъект.Дата &lt;&gt; СвойстваПоиска["Дата"] ИЛИ СсылкаНаОбъект.Номер &lt;&gt; СвойстваПоиска["Номер"] ИЛИ СсылкаНаОбъект.ДокументБУ &lt;&gt; лДокументБУ Тогда
		ТекОбъект = СсылкаНаОбъект.ПолучитьОбъект();
		ТекОбъект.Дата = СвойстваПоиска["Дата"];
		ТекОбъект.Номер = СвойстваПоиска["Номер"];
		//ТекОбъект.ТипОбъекта = ?(СвойстваПоиска["ТипОбъекта"] = Неопределено, СтрЗаменить(ТипОбъекта, "Документ ссылка: ", ""), СвойстваПоиска["ТипОбъекта"]);
		ТекОбъект.Наименование = лДокументБУ;
		ТекОбъект.ДокументБУ = лДокументБУ;
		ТекОбъект.Записать(); 		
	КонецЕсли;	
	Если (ТипОбъекта = "Поступление из переработки" И НЕ ТипОбъекта = СсылкаНаОбъект.ТипОбъекта) Тогда
		ТекОбъект = СсылкаНаОбъект.ПолучитьОбъект();
		ТекОбъект.ТипОбъекта = "Поступление из переработки"; 		
		ТекОбъект.Записать();  		
	КонецЕсли;   		
Иначе
	НовыйЭлемент = Справочники.УБИ_ПотерянныеДокументыИзБУ.СоздатьЭлемент();	
	НовыйЭлемент.УникальныйИдентификатор = СвойствоУникальныйИдентификатор;
	НовыйЭлемент.Дата = СвойстваПоиска["Дата"];
	НовыйЭлемент.Номер = СвойстваПоиска["Номер"];
	НовыйЭлемент.ТипОбъекта = ?(СвойстваПоиска["ТипОбъекта"] = Неопределено, СтрЗаменить(ТипОбъекта, "Документ ссылка: ", ""), СвойстваПоиска["ТипОбъекта"]);
	НовыйЭлемент.Наименование = лДокументБУ;
	НовыйЭлемент.ДокументБУ = лДокументБУ;
	НовыйЭлемент.Записать();
	СсылкаНаОбъект = НовыйЭлемент.Ссылка; 
КонецЕсли;

Если НЕ ЗначениеЗаполнено(СсылкаНаОбъект.ДокументАналогВУТ) 
	И (ТипОбъекта = Тип("ДокументСсылка.ВозвратТоваровОтПокупателя") 
	ИЛИ СсылкаНаОбъект.ТипОбъекта = "Поступление из переработки") Тогда
	
	Выполнить(Алгоритмы.НайтиДокументАналогВУТ);
	
КонецЕсли;</Текст>
		</Алгоритм>
	</Алгоритмы>
